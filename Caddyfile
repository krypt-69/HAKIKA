:8080 {
    # Redirect bare paths to slash-terminated versions
    @customer {
        path /customer
    }
    redir @customer /customer/ permanent

    @business {
        path /business
    }
    redir @business /business/ permanent

    @rider {
        path /rider
    }
    redir @rider /rider/ permanent

    @admin {
        path /admin
    }
    redir @admin /admin/ permanent

    # Root redirect to customer app
    handle / {
        redir /customer/ permanent
    }

    # Customer App
    handle /customer/* {
        reverse_proxy localhost:3002
    }

    # Business App
    handle /business/* {
        reverse_proxy localhost:3001
    }

    # Rider App
    handle /rider/* {
        reverse_proxy localhost:3003
    }

    # Admin App
    handle /admin/* {
        reverse_proxy localhost:3004
    }

    # Backend API
    handle /api/v1/* {
        reverse_proxy localhost:8000
    }

    # Uploads
    handle /uploads/* {
        reverse_proxy localhost:8000
    }
}
